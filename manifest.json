{
  "manifest_version": 3,
  "name": "Email Senders to Address Book",
  "version": "2.1.1",
  "description": "Automatically add email senders to address book and scan new emails daily",
  "author": "Adam Zagórski",
  "permissions": [
    "accountsRead",
    "messagesRead",
    "menus",
    "alarms",
    "storage",
    "addressBooks"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": false
  },
  "action": {
    "default_title": "Email Senders Extractor",
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "email-senders-extractor@local",
      "strict_min_version": "102.0"
    }
  }
}
